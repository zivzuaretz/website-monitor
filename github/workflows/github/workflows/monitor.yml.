name: Website Monitor

on:
  schedule:
    - cron: "0 5,17 * * *"   # 08:00 ו-20:00 שעון ישראל (UTC+3)
  workflow_dispatch:           # אפשרות הפעלה ידנית

jobs:
  monitor:
    runs-on: ubuntu-latest
    permissions:
      contents: write

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Install dependencies
        run: pip install requests beautifulsoup4

      - name: Run monitor
        env:
          GMAIL_FROM: ${{ secrets.GMAIL_FROM }}
          GMAIL_TO: ${{ secrets.GMAIL_TO }}
          GMAIL_APP_PASSWORD: ${{ secrets.GMAIL_APP_PASSWORD }}
        run: python monitor.py

      - name: Save snapshots to repo
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          git add snapshots.json
          git diff --staged --quiet || git commit -m "chore: update snapshots $(date -u +%Y-%m-%dT%H:%M:%SZ)"
          git push
